<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002-create-restaurants" author="webresto">
        <createTable tableName="restaurants">
            <column name="id"              type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="nom"             type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="description"     type="TEXT"/>
            <column name="adresse"         type="VARCHAR(500)"/>
            <column name="ville"           type="VARCHAR(100)"/>
            <column name="telephone"       type="VARCHAR(20)"/>
            <column name="image_url"       type="VARCHAR(1000)"/>
            <column name="categorie_id"    type="BIGINT"><constraints foreignKeyName="fk_resto_cat" references="categories(id)"/></column>
            <column name="proprietaire_id" type="BIGINT"/>
            <column name="actif" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
